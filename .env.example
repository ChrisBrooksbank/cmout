# Chelmsford Events Aggregator - API Keys
# Copy this to .env and fill in your keys

# Skiddle API - Get key at https://www.skiddle.com/api/join.php
SKIDDLE_API_KEY=

# Ents24 API - Register at https://developers.ents24.com/
ENTS24_CLIENT_ID=
ENTS24_CLIENT_SECRET=

# Ticketmaster Discovery API - Get key at https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Optional: iCal feed URLs (comma-separated)
ICAL_FEED_URLS=
