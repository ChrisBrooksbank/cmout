{
  "name": "cmout",
  "version": "0.2.0",
  "description": "Chelmsford Local Events Aggregator - Data source verification prototype",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "preview:ui": "vite preview",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "fetch:openactive": "tsx src/cli.ts --source openactive",
    "fetch:skiddle": "tsx src/cli.ts --source skiddle",
    "fetch:ents24": "tsx src/cli.ts --source ents24",
    "fetch:ticketmaster": "tsx src/cli.ts --source ticketmaster",
    "fetch:ical": "tsx src/cli.ts --source ical",
    "fetch:dice": "tsx src/cli.ts --source dice",
    "fetch:wegottickets": "tsx src/cli.ts --source wegottickets",
    "fetch:meetup": "tsx src/cli.ts --source meetup",
    "fetch:all": "tsx src/cli.ts --source all",
    "build:events": "tsx src/build-events.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "knip": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "node-ical": "^0.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "domhandler": "^5.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "husky": "^9.0.0",
    "jsdom": "^25.0.0",
    "knip": "^5.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
